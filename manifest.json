{
  "manifest_version": 3,
  "name": "WebLang Translator",
  "description": "Powerful web page translation extension with AI integration.",
  "version": "2.0.0",
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "downloads",
    "sidePanel"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": "assets/icon-48.png"
  },
  "side_panel": {
    "default_path": "popup/popup.html"
  },
  "options_page": "options/options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*",
    "file://*/*"
  ]
}
